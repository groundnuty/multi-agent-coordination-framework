{
  "name": "@groundnuty/macf-channel-server",
  "version": "0.2.3",
  "description": "MCP channel server for the Multi-Agent Coordination Framework. HTTPS + mTLS endpoint agents connect to for inter-agent messaging (notify), CI-completion routing, and /sign certificate issuance. Invoked by Claude Code's plugin via `npx -y @groundnuty/macf-channel-server` per DR-022.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "macf-channel-server": "dist/server.js"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/groundnuty/macf.git",
    "directory": "packages/macf-channel-server"
  },
  "homepage": "https://github.com/groundnuty/macf#readme",
  "bugs": "https://github.com/groundnuty/macf/issues",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "check": "tsc -b && eslint src/ && vitest run",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@groundnuty/macf-core": "0.2.3",
    "@modelcontextprotocol/sdk": "~1.29.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "0.215.0",
    "@opentelemetry/resources": "2.7.0",
    "@opentelemetry/sdk-trace-base": "2.7.0",
    "@opentelemetry/sdk-trace-node": "2.7.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.0.0"
  }
}
