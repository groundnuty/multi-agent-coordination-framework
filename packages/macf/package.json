{
  "name": "@groundnuty/macf",
  "version": "0.2.2",
  "description": "Multi-Agent Coordination Framework CLI — coordinate Claude Code agents via GitHub. Installs as `macf` binary; use `macf init` to set up an agent workspace, `macf update` to refresh rules + version pins.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "macf": "dist/cli/index.js",
    "macf-plugin-cli": "dist/plugin/bin/macf-plugin-cli.js"
  },
  "files": [
    "dist/",
    "plugin/rules/",
    "scripts/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/groundnuty/macf.git",
    "directory": "packages/macf"
  },
  "homepage": "https://github.com/groundnuty/macf#readme",
  "bugs": "https://github.com/groundnuty/macf/issues",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "postbuild": "node scripts/write-build-info.mjs",
    "typecheck": "tsc -b",
    "check": "tsc -b && eslint src/ && vitest run",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@groundnuty/macf-core": "0.2.2",
    "commander": "^14.0.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.0.0"
  }
}
