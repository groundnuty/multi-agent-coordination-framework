{
  "name": "macf",
  "version": "0.1.1",
  "description": "Multi-Agent Coordination Framework — coordinate Claude Code agents via GitHub and MCP channels",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "macf": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "plugin/rules/",
    "scripts/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/write-build-info.mjs",
    "check": "tsc --noEmit && eslint src/ && vitest run",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "0.215.0",
    "@opentelemetry/resources": "2.7.0",
    "@opentelemetry/sdk-trace-base": "2.7.0",
    "@opentelemetry/sdk-trace-node": "2.7.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@peculiar/webcrypto": "^1.5.0",
    "@peculiar/x509": "^2.0.0",
    "commander": "^14.0.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.0"
  }
}
