{
  "_COMMENT": "Copy this to settings.local.json and fill in APP_ID / INSTALL_ID after creating the macf-code-agent GitHub App. The real settings.local.json is gitignored.",
  "env": {
    "APP_ID": "REPLACE_WITH_APP_ID",
    "INSTALL_ID": "REPLACE_WITH_INSTALLATION_ID",
    "KEY_PATH": ".github-app-key.pem",
    "GIT_AUTHOR_NAME": "macf-code-agent[bot]",
    "GIT_AUTHOR_EMAIL": "REPLACE_WITH_BOT_USER_ID+macf-code-agent[bot]@users.noreply.github.com",
    "GIT_COMMITTER_NAME": "macf-code-agent[bot]",
    "GIT_COMMITTER_EMAIL": "REPLACE_WITH_BOT_USER_ID+macf-code-agent[bot]@users.noreply.github.com"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:cache.nixos.org)",
      "WebFetch(domain:releases.jetify.com)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TMUX\" ]; then TOKEN=$(gh token generate --app-id $APP_ID --installation-id $INSTALL_ID --key $KEY_PATH 2>/dev/null | jq -r '.token'); ISSUES=$(GH_TOKEN=$TOKEN gh issue list --repo groundnuty/macf --label code-agent --state open --json number,title --jq '[.[0:5] | .[] | \"#\\(.number): \\(.title)\"] | join(\"; \")' 2>/dev/null); if [ -n \"$ISSUES\" ]; then sleep 3 && \"$CLAUDE_PROJECT_DIR/.claude/scripts/tmux-send-to-claude.sh\" \"\" \"Pick up pending issues: $ISSUES\" & fi; fi",
            "async": true
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enableWeakerNetworkIsolation": true
  }
}
